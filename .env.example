# self-media-system local config
# Copy to ~/.self-media-system/.env, then fill only the values you need.

# Required only for content-image-gen.
ARK_API_KEY=
SEEDREAM_IMAGE_MODEL=doubao-seedream-5-0-260128
SEEDREAM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Required only when pushing WeChat drafts from wechat-studio.
WECHAT_APP_ID=
WECHAT_APP_SECRET=
